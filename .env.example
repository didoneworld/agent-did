DATABASE_URL=postgresql+psycopg2://agentid:agentid@db:5432/agentid
PORT=8000
APP_PORT=8000
POSTGRES_PORT=5432
API_RATE_LIMIT_REQUESTS=120
API_RATE_LIMIT_WINDOW_SECONDS=60
SESSION_SIGNING_SECRET=change-me
SESSION_TTL_SECONDS=43200

# ── Phase 1: Identity hardening ───────────────────────────────────────────────
# RS256 signing key pair  (openssl genrsa -out key.pem 2048)
SIGNING_KEY_PRIVATE_PEM=
SIGNING_KEY_PUBLIC_PEM=
SIGNING_KEY_ID=agent-did-key-1

# Session
SESSION_TTL_SECONDS=3600
POST_LOGOUT_REDIRECT=https://agent-id.openautonomyx.com/logged-out

# SAML SP  (openssl req -x509 -newkey rsa:2048 -keyout sp.key -out sp.crt -days 3650 -nodes)
SAML_SP_CERT=
SAML_SP_KEY=

# ── Phase 2: SCIM + SSF ───────────────────────────────────────────────────────
CAAS_API_GATEWAY_URL=http://localhost:3001

# ── Phase 3: AuthZEN / Agent-Auth wiring ─────────────────────────────────────
# Agent-Auth PDP (Agent-Auth repo: openagx/Agent-Auth)
# Falls back to CAAS_API_GATEWAY_URL if AGENT_AUTH_URL is empty
AGENT_AUTH_URL=
AGENT_AUTH_API_KEY=
AGENT_AUTH_TIMEOUT_SECONDS=3.0
# fail-open: allow when PDP unreachable (set false in prod)
AUTHZEN_FAIL_OPEN=true
